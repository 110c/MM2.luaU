local destroyButton = Instance.new("TextButton")
destroyButton.Parent = frame
destroyButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
destroyButton.TextColor3 = Color3.fromRGB(255, 255, 255)
destroyButton.Size = UDim2.new(0, 150, 0, 25)
destroyButton.Position = UDim2.new(0, 15, 0, 85)
destroyButton.Text = "Destroy"
destroyButton.TextScaled = true
destroyButton.Font = Enum.Font.Gotham

local destroyCorner = Instance.new("UICorner")
destroyCorner.CornerRadius = UDim.new(0, 6)
destroyCorner.Parent = destroyButton

local highlightEnabled = false
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local roles
local Murder, Sheriff, Hero

function CreateHighlight()
    if highlightEnabled then
        for _, v in pairs(Players:GetChildren()) do
            if v ~= player and v.Character and not v.Character:FindFirstChild("Highlight") then
                Instance.new("Highlight", v.Character)
            end
        end
    end
end

function UpdateHighlights()
    if highlightEnabled then
        for _, v in pairs(Players:GetChildren()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("Highlight") then
                local Highlight = v.Character:FindFirstChild("Highlight")
                if v.Name == Sheriff and IsAlive(v) then
                    Highlight.FillColor = Color3.fromRGB(0, 0, 225)
                elseif HasGun(v) and IsAlive(v) then
                    Highlight.FillColor = Color3.fromRGB(0, 0, 225)
                elseif v.Name == Murder and IsAlive(v) then
                    Highlight.FillColor = Color3.fromRGB(225, 0, 0)
                elseif v.Name == Hero and IsAlive(v) and not IsAlive(game.Players[Sheriff]) then
                    Highlight.FillColor = Color3.fromRGB(255, 250, 0)
                else
                    Highlight.FillColor = Color3.fromRGB(0, 225, 0)
                end
            end
        end
    end
end

function IsAlive(Player)
    for i, v in pairs(roles) do
        if Player.Name == i then
            if not v.Killed and not v.Dead then return true else return false end
        end
    end
    return false
end

function HasGun(Player)
    for i, v in pairs(roles) do
        if Player.Name == i and v.HasGun then return true end
    end
    return false
end

onButton.MouseButton1Click:Connect(function()
    highlightEnabled = true
    statusLabel.Text = "Status: On"
    statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
end)

offButton.MouseButton1Click:Connect(function()
    highlightEnabled = false
    statusLabel.Text = "Status: Off"
    statusLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    
    for _, v in pairs(Players:GetChildren()) do
        if v.Character and v.Character:FindFirstChild("Highlight") then
            v.Character:FindFirstChild("Highlight"):Destroy()
        end
    end
end)

destroyButton.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

RunService.RenderStepped:Connect(function()
    if highlightEnabled then
        roles = ReplicatedStorage:FindFirstChild("GetPlayerData", true):InvokeServer()
        
        for i, v in pairs(roles) do
            if v.Role == "Murderer" then Murder = i
            elseif v.Role == "Sheriff" then Sheriff = i
            elseif v.Role == "Hero" then Hero = i end
        end
        
        CreateHighlight()
        UpdateHighlights()
    end
end)
