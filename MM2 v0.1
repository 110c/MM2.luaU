corner.Parent = frame

local statusLabel = Instance.new("TextLabel")
statusLabel.Parent = frame
statusLabel.BackgroundTransparency = 1
statusLabel.Size = UDim2.new(1, 0, 0, 30)
statusLabel.Position = UDim2.new(0, 0, 0, 10)
statusLabel.Text = "Status: Off"
statusLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
statusLabel.TextScaled = true
statusLabel.Font = Enum.Font.Gotham

local onButton = Instance.new("TextButton")
onButton.Parent = frame
onButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
onButton.TextColor3 = Color3.fromRGB(0, 0, 0)
onButton.Size = UDim2.new(0, 70, 0, 28)
onButton.Position = UDim2.new(0, 15, 0, 50)
onButton.Text = "On"
